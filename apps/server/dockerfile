# ─── Stage 1: Builder ────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/server/package.json ./apps/server/
COPY apps/shared/package.json ./apps/shared/

RUN pnpm install --frozen-lockfile

COPY . .

RUN pnpm turbo run build --filter=@elecshop/server

# ─── Stage 2: Runner ─────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

# Do NOT hardcode PORT — Azure App Service injects its own PORT at runtime.
# main.ts already handles: const port = process.env.PORT || 4000
EXPOSE 5000

# Copy the server distribution files
COPY --from=builder /app/apps/server/dist ./apps/server/dist

# Copy local node_modules of server and root node_modules to preserve symlinks
COPY --from=builder /app/apps/server/node_modules ./apps/server/node_modules
COPY --from=builder /app/node_modules ./node_modules

# Copy shared packages
COPY --from=builder /app/apps/shared ./apps/shared

# Set working directory to the server app to let Node resolve the local dependencies
WORKDIR /app/apps/server
CMD ["node", "dist/main.js"]